# Telegram bot token (only needed for main.py, not for web_app.py)
BOT_TOKEN=123456789:AABBCCDDEEFFaabbccddeeff

# === OPTION A: Standard OpenAI ===
# OPENAI_API_KEY=sk-proj-...
# OPENAI_MODEL=gpt-4o-mini

# === OPTION B: Custom endpoint (QCHEM, Ollama, vLLM, etc.) ===
OPENAI_API_KEY=your_qchem_key
OPENAI_API_BASE=https://your-qchem-endpoint.com/v1
OPENAI_MODEL=Openai/Gpt-oss-120b

# Alternative variable names (also supported)
# QCHEM_API_KEY=your_key
# QCHEM_BASE_URL=https://your-endpoint.com/v1
